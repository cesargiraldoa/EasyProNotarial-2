# Backend FastAPI — Railway en producción / 8001 en local (8000 reservado para Gari)
NEXT_PUBLIC_API_URL=http://127.0.0.1:8001

# Nombre de la aplicación
NEXT_PUBLIC_APP_NAME=EasyPro 2

# URL del frontend para callbacks
NEXT_PUBLIC_FRONTEND_URL=http://127.0.0.1:5179

# URL de OnlyOffice Document Server (Digital Ocean)
NEXT_PUBLIC_ONLYOFFICE_DOCS_URL=https://onlyoffice.easypronotarial.com

# JWT Secret compartido con OnlyOffice (debe coincidir con la config del servidor)
ONLYOFFICE_JWT_SECRET=cambia-esto-por-un-secreto-seguro
